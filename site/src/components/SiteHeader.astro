---
import WatchButton from './WatchButton.astro';
import { LINKS } from './siteConfig';
type Props = { active?: string };
const { active = '' } = Astro.props;

const nav = [
  { href: '/cv', label: 'CV', key: 'cv' },
  { href: '/projects', label: 'Projects', key: 'projects' },
  { href: '/lab', label: 'Lab', key: 'lab' },
  { href: '/engineering', label: 'Engineering', key: 'engineering' },
  { href: '/press-kit', label: 'Press Kit', key: 'press-kit' },
  { href: '/links', label: 'Links', key: 'links' },
  { href: '/contact', label: 'Contact', key: 'contact' },
];
---

<header class="hdr">
  <div class="inner">
    <a class="logo" href="/">
      <span class="mark"><img src="/assets/favicon-32.png" alt="ExNulla" /></span>
      <span class="word">ExNulla</span>
    </a>

    <nav class="nav">
      {
        nav.map((i) => (
          <a class:list={['item', active === i.key && 'active']} href={i.href}>
            {i.label}
          </a>
        ))
      }
    </nav>

    <div class="cta">
      <a class="btn ghost" href={LINKS.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      <WatchButton />
    </div>
  </div>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--bg) 86%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 14px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--fg);
    font-weight: 700;
  }
  .mark {
    width: 28px;
    height: 28px;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    background: var(--card);
    font-size: 14px;
    opacity: 0.9;
  }
  .mark img {
    width: 18px;
    height: 18px;
    display: block;
    object-fit: contain;
  }

  .nav {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .item {
    text-decoration: none;
    color: var(--muted);
    padding: 6px 8px;
    border-radius: 10px;
  }
  .item:hover {
    color: var(--fg);
    background: color-mix(in oklab, var(--card) 75%, transparent);
  }
  .active {
    color: var(--fg);
    border: 1px solid var(--border);
    background: var(--card);
  }
  .cta {
    display: flex;
    gap: 10px;
  }
  .btn {
    text-decoration: none;
    border-radius: 12px;
    padding: 9px 12px;
    font-weight: 600;
    font-size: 14px;
    border: 1px solid var(--border);
  }
  .ghost {
    background: transparent;
    color: var(--fg);
  }
  .primary {
    background: var(--fg);
    color: var(--bg);
    border-color: color-mix(in oklab, var(--fg) 70%, var(--border));
  }
</style>
