---
const fallbackUrl = "https://kick.com/exnulla";
---

<a id="watch-btn" href={fallbackUrl} target="_blank" class="watch-button flex items-center gap-2 px-6 py-3 rounded-full border border-white/30 hover:border-white/60 transition-all">
  <span id="status-dot" class="w-3 h-3 rounded-full bg-red-500 animate-pulse"></span>
  <span id="status-text" class="font-medium">Watch on Kick</span>
</a>

<script>
  const btn = document.getElementById('watch-btn');
  const dot = document.getElementById('status-dot');
  const text = document.getElementById('status-text');

  async function checkLiveStatus() {
    try {
      const res = await fetch('/stream/status.json', { cache: 'no-cache' });
      if (!res.ok) throw new Error();
      const data = await res.json();

      if (data.status === 'live') {
        dot.classList.remove('bg-red-500');
        dot.classList.add('bg-green-500', 'animate-ping');
        text.textContent = 'LIVE NOW →';
        btn.href = data.url;
        btn.classList.add('!border-green-400', '!text-green-400');
      } else {
        dot.classList.remove('bg-green-500', 'animate-ping');
        dot.classList.add('bg-red-500');
        text.textContent = 'Watch on Kick';
      }
    } catch (e) {
      // fallback silent
    }
  }

  // Check immediately + every 30s while page open
  checkLiveStatus();
  setInterval(checkLiveStatus, 30000);
</script>
