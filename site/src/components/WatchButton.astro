---
const fallbackUrl = "https://www.twitch.tv/exnulla";
---

<a id="watch-btn" href={fallbackUrl} target="_blank" rel="noreferrer" class="btn ghost watch">
  <span id="status-dot" class="dot"></span>
  <span id="status-text">Watch on Twitch</span>
</a>

<script>
  const btn = document.getElementById('watch-btn');
  const dot = document.getElementById('status-dot');
  const text = document.getElementById('status-text');

  async function checkLiveStatus() {
    try {
      const res = await fetch('/stream/status.json', { cache: 'no-cache' });
      if (!res.ok) throw new Error();
      const data = await res.json();

      if (data.live === true || data.isLive === true) {
        dot.classList.add('live');
        const title = data.title ? ` — ${data.title.slice(0, 45)}${data.title.length > 45 ? '...' : ''}` : '';
        text.textContent = `LIVE NOW${title}`;
        btn.href = data.url || fallbackUrl;
      } else {
        dot.classList.remove('live');
        text.textContent = 'Watch on Twitch';
        btn.href = fallbackUrl;
      }
    } catch (e) {
      // silent fallback
      dot.classList.remove('live');
      text.textContent = 'Watch on Twitch';
    }
  }

  // Check immediately + every 30s (matches your cron)
  checkLiveStatus();
  setInterval(checkLiveStatus, 30000);
</script>

<style>
  .btn{
    text-decoration:none;
    border-radius:12px;
    padding:9px 12px;
    font-weight:600;
    font-size:14px;
    border:1px solid var(--border);
    display:inline-flex;
    align-items:center;
    gap:10px;
  }
  .ghost{ background:transparent; color:var(--fg); }
  .watch{ transition: border-color 120ms ease, background 120ms ease, color 120ms ease; }
  .watch:hover{ background:color-mix(in oklab, var(--card) 75%, transparent); }
  .dot{ width:10px; height:10px; border-radius:999px; background:#ef4444; }
  .dot.live{ background:#22c55e; }
</style>
