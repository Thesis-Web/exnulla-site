---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LINKS } from '../components/siteConfig';
---

<BaseLayout
  title="Press Kit — ExNulla"
  description="Background, positioning, and contact information for ExNulla."
  active="press-kit"
>
  <div class="kicker">Press Kit</div>
  <h1 class="h1">Press Kit</h1>
  <p class="sub">
    Background and contact context for collaborators, podcasts, recruiters, founders, and technical
    write-ups.
  </p>

  <div class="btnrow">
    <a class="btn primary" href="/cv">Open CV</a>
    <a class="btn ghost" href="/projects">View Projects</a>
    <a class="btn ghost" href={LINKS.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
    <a class="btn ghost" href="/contact">Contact</a>
  </div>

  <div class="hr"></div>

  <section class="card">
    <h2>Overview</h2>
    <p>
      ExNulla is a public engineering ecosystem built to demonstrate systems architecture,
      infrastructure discipline, and execution in the open.
    </p>
    <p>
      Built a complete public engineering ecosystem from initial concept to production —
      architecture, repositories, CI/CD, infrastructure, demos, documentation, and developer
      workflow — in 23 days as a single operator using a structured AI-assisted development
      pipeline.
    </p>
  </section>

  <div class="hr"></div>

  <section class="grid grid-2">
    <div class="card">
      <h2>What ExNulla demonstrates</h2>
      <ul class="list">
        <li>Constraints-first systems design rather than presentation-first portfolio work.</li>
        <li>Deterministic build and deployment thinking across docs, code, and infrastructure.</li>
        <li>
          Public proof-of-work: case studies, runnable demos, streams, and engineering artifacts.
        </li>
        <li>
          End-to-end operator ownership across design, architecture, build, deploy, and narrative.
        </li>
      </ul>
    </div>

    <div class="card">
      <h2>Relevant audiences</h2>
      <ul class="list">
        <li>Hiring managers evaluating senior engineering judgment and real proof-of-work.</li>
        <li>Founders seeking architecture plus execution, not just implementation.</li>
        <li>
          Organizations—large or small, new or established—looking to optimize systems, remove
          inefficiencies, and scale deterministically.
        </li>
        <li>
          Businesses exploring product optimization, market opportunity discovery, and technical
          strategies to create competitive advantage.
        </li>
      </ul>
    </div>
  </section>

  <div class="hr"></div>

  <section class="grid grid-2">
    <div class="card">
      <h2>About James Huson</h2>
      <p class="small">
        I am a systems-focused builder working across architecture, infrastructure, deployment,
        documentation, and public technical narrative. ExNulla is the operating proof: not a static
        portfolio, but a working engineering environment I designed, built, and operate in public.
      </p>
    </div>

    <div class="card">
      <h2>Core themes</h2>
      <div class="pillrow">
        <span class="pill">Systems Architecture</span>
        <span class="pill">Infrastructure</span>
        <span class="pill">CI/CD</span>
        <span class="pill">Static-First</span>
        <span class="pill">Public Proof-of-Work</span>
        <span class="pill">AI-Assisted Development</span>
      </div>
    </div>
  </section>

  <div class="hr"></div>

  <section class="card">
    <h2>Contact and references</h2>
    <div class="btnrow">
      <a class="btn ghost" href={LINKS.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      <a class="btn ghost" href={LINKS.github} target="_blank" rel="noreferrer">GitHub</a>
      <a class="btn ghost" href={LINKS.youtube} target="_blank" rel="noreferrer">YouTube</a>
      <a class="btn ghost" href={LINKS.kick} target="_blank" rel="noreferrer">Kick</a>
    </div>
    <p class="small" style="margin-top:12px">
      For interviews, collaborations, or technical discussions, use the contact page or LinkedIn.
    </p>
  </section>
</BaseLayout>
