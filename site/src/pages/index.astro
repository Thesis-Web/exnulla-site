---
import BaseLayout from "../layouts/BaseLayout.astro";
import { LINKS, PROOF_OF_TALENT } from "../components/siteConfig";
---

<BaseLayout
  title="Systems Architecture — ExNulla"
  description="Static-first portfolio with isolated simulations, atomic releases, and verifiable build provenance."
  active=""
>
  <h1 class="h1">Systems Architecture. Deterministic Execution.</h1>

  <p class="sub">
    Static-first portfolio with isolated simulations, atomic releases,
    and verifiable build provenance.
  </p>

  <div class="btnrow">
    <a class="btn primary" href={LINKS.kick} target="_blank" rel="noreferrer">
      Watch Live
    </a>
    <a class="btn ghost" href="/projects">Projects</a>
    <a class="btn ghost" href="/lab">Lab</a>
    <a class="btn ghost" href="/meta">Meta</a>
  </div>

  <div class="hr"></div>

  <section>
    <h2>Design for Constraints</h2>
    <p>
      Systems are shaped by limits. Architecture begins with constraints,
      not features. This site reflects that discipline.
    </p>
    <ul class="list">
      <li>Static-first rendering.</li>
      <li>Explicit runtime isolation.</li>
      <li>Atomic deploys with rollback.</li>
      <li>Build provenance on every release.</li>
    </ul>
  </section>

  <div class="hr"></div>

  <section>
    <h2>Featured Case</h2>
    <p>
      Deterministic attest pipeline for hostile JSON ingestion,
      canonicalization, hashing, and rule-based decisioning.
    </p>
    <div class="btnrow">
      <a class="btn ghost" href="/projects/exnulla-site">
        View Case Study
      </a>
    </div>
  </section>

  <div class="hr"></div>

  <section>
    <h2>Interactive Simulation</h2>
    <p>
      Isolated runtime simulation. Loaded on demand. No shell pollution.
    </p>
    <div class="btnrow">
      <a class="btn ghost" href="/lab">Open Lab</a>
    </div>
  </section>

  <div class="hr"></div>

  <!-- Terminal block will be inserted here in next step -->

  <div class="hr"></div>

  <section class="identity">
    <div class="identity-inner">
      <img
        src="/assets/James-Headshot.jpg"
        alt="James Huson"
        loading="lazy"
      />
      <div>
        <strong>James Huson</strong>
        <div class="small">Systems Architect</div>
      </div>
    </div>

    <div class="btnrow" style="justify-content:center;">
      <a class="btn ghost" href={LINKS.linkedin} target="_blank" rel="noreferrer">
        LinkedIn
      </a>
      <a class="btn ghost" href={LINKS.github} target="_blank" rel="noreferrer">
        GitHub
      </a>
      <a class="btn ghost" href={LINKS.kick} target="_blank" rel="noreferrer">
        Kick
      </a>
    </div>
  </section>
<!-- PROOF-OF-TALENT SECTION — 6 creative architecture showcases -->
<section class="proof-of-work py-16 border-t border-white/10">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-4xl font-bold mb-4">Proof of Talent</h2>
    <p class="text-xl text-white/70 mb-12">6× systems I built that solve real problems most people ignore.</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {PROOF_OF_TALENT.map((item) => (
        <div class="bg-zinc-950 border border-white/10 rounded-2xl p-8 hover:border-white/30 transition-all group">
          <div class="flex justify-between items-start mb-6">
            <div>
              <h3 class="text-2xl font-semibold group-hover:text-white transition-colors">{item.title}</h3>
              <p class="text-white/60 text-sm mt-1">{item.subtitle}</p>
            </div>
            <span class="px-3 py-1 text-xs rounded-full border border-white/20 text-white/60">{item.type}</span>
          </div>
          
          <p class="text-white/80 text-sm leading-relaxed mb-8">{item.wow}</p>
          
          <a href={item.repo} target="_blank" class="inline-flex items-center gap-2 text-sm text-white/70 hover:text-white transition-colors">
            View repo →
          </a>
          {item.demoPath && item.status === 'live' && (
            <a href={item.demoPath} class="ml-4 text-green-400 text-sm">→ live demo</a>
          )}
          {item.status === 'todo-sim' && (
            <span class="ml-4 text-amber-400 text-sm">sim coming next push</span>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

  <style>
    .identity {
      text-align: center;
      padding-top: 20px;
    }

    .identity-inner {
      display: inline-flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 16px;
    }

    .identity img {
      width: 90px;
      height: 90px;
      border-radius: 16px;
      object-fit: cover;
      border: 1px solid var(--border);
      background: var(--card);
    }
  </style>
</BaseLayout>
