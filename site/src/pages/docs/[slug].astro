---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return [{ params: { slug: 'intent-file-router' } }];
}

const { slug } = Astro.params;

const docs = import.meta.glob('../../content/docs/*.md', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

const key = `../../content/docs/${slug}.md`;

const content =
  docs[key] ??
  `# Documentation Not Found

No documentation exists yet for **${slug}**.
`;
---

<BaseLayout title={`Docs — ${slug}`}>
  <div class="kicker">Documentation</div>
  <h1 class="h1">{slug}</h1>

  <div class="hr"></div>

  <article class="card">
    <pre class="code" style="white-space: pre-wrap; margin: 0;">{content}</pre>
  </article>
</BaseLayout>
