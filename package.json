{
  "name": "exnulla-site",
  "private": true,
  "packageManager": "npm@10.8.2",
  "scripts": {
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "lint:md": "markdownlint-cli2",
    "lint": "npm run lint:md && npm run format:check",
    "build": "npm --prefix site ci && npm --prefix site run build",
    "dev": "npm --prefix site run dev",
    "preview": "npm --prefix site run preview",
    "gate": "npm run lint && npm run typecheck --if-present"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.14.0",
    "prettier": "^3.8.1"
  },
  "version": "1.0.0",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
